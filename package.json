{
  "name": "indiatv",
  "version": "1.0.0",
  "private": true,
  "description": "IndiaTV - Anonymous Random Video Chat Platform",
  "workspaces": [
    "frontend",
    "backend",
    "config",
    "simulator"
  ],
  "scripts": {
    "dev": "vercel dev",
    "dev:frontend": "npm run dev -w indiatv-frontend",
    "build": "npm run build -w config && npm run build -w indiatv-frontend && node scripts/copy-build.js && npm run build --prefix backend",
    "start": "node backend/dist/index.js",
    "preview": "npm run preview -w indiatv-frontend",
    "typecheck": "npm run typecheck -w indiatv-frontend",
    "certify": "cd simulator && npx tsx src/index.ts",
    "certify:full": "concurrently --kill-others \"npm run dev -w indiatv-backend\" \"npm run dev -w indiatv-frontend\" \"node -e \\\"setTimeout(() => require('child_process').execSync('npx tsx simulator/src/index.ts --users=100', {stdio:'inherit', cwd: process.cwd()}), 15000)\\\"\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/web-push": "^3.6.4",
    "pg": "^8.22.0",
    "typescript": "^5.8.2",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@vercel/node": "^5.1.14",
    "concurrently": "^9.1.2",
    "vercel": "^41.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Maheswarreddyk/7-4-2026-kaboom.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Maheswarreddyk/7-4-2026-kaboom/issues"
  },
  "homepage": "https://github.com/Maheswarreddyk/7-4-2026-kaboom#readme"
}
