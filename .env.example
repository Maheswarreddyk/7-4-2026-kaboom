# =========================================================================
# IndiaTV Production Environment Template
# =========================================================================

# --- Application Settings ---
# [Required] [Production & Development]
APP_NAME=Kaboom TV
# [Required] [Production] Primary client domain
APP_URL=https://kaboom-tv.com
# [Optional] [Production] Leave blank to default to dynamic same-origin requests
API_URL=
WS_URL=
# [Required] [Production & Development] ('supabase' or 'socket.io')
SIGNALING_PROVIDER=supabase
# [Required] [Production & Development] ('production' or 'development')
NODE_ENV=production

# --- Supabase Credentials ---
# [Required] [Production & Development] Supabase project URL
SUPABASE_URL=https://khdchqwieoqljevdhpvc.supabase.co
# [Required] [Production & Development] Public anonymous client key (safe for client side)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtoZGNocXdpZW9xbGpldmRocHZjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ2MTcxODUsImV4cCI6MjEwMDE5MzE4NX0.GEyVVWlMZB-gbFV7QTVmbVCkMSJ3s507aHRYRiYP51Q
# [Required] [Secret] [Backend Only] High-privilege role key (NEVER commit this value!)
SUPABASE_SERVICE_ROLE_KEY=

# --- Backend Settings ---
# [Required] [Production & Development] Port backend server listens on
PORT=5000
# [Required] [Production] Allowlist origin url
FRONTEND_URL=https://kaboom-tv.com
# [Optional] [Production & Development] Base routing path
API_BASE=/api
# [Optional] [Production & Development] Session timeouts (in seconds)
SESSION_TIMEOUT=1800
QUEUE_TIMEOUT=300
MATCH_TIMEOUT=1800
# [Optional] [Production] Comma-separated list of allowed origins. Defaults to: https://kaboom-tv.com,https://www.kaboom-tv.com
ALLOWED_ORIGINS=https://kaboom-tv.com,https://www.kaboom-tv.com,https://api.kaboom-tv.com,https://seven-4-2026-kaboom-1a.onrender.com

# --- WebRTC Settings ---
# [Required] [Production & Development] Commas-separated list of STUN servers
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302
# [Optional] [Secret] [Production] TURN relay server address (highly recommended for production)
TURN_SERVER=
TURN_USERNAME=
TURN_PASSWORD=

# --- Admin Settings ---
# [Required] [Secret] [Production] Password/token to access backend admin/analytics endpoints
ADMIN_TOKEN=
# [Required] [Secret] [Production] Secret used to sign session cookies and tokens
JWT_SECRET=

# --- Email Settings ---
# [Optional] [Production & Development] Support/Contact contact channels
CONTACT_EMAIL=contact@kaboom-tv.com
SUPPORT_EMAIL=support@kaboom-tv.com

# --- Frontend Env Variables (Vite Prefixed) ---
# Note: Vite loads these variables on the client side at build time.
# Omit VITE_API_URL and VITE_WS_URL in production to leverage dynamic same-origin requests.
VITE_APP_NAME=Kaboom TV
VITE_APP_URL=https://kaboom-tv.com
VITE_API_URL=
VITE_WS_URL=
VITE_SIGNALING_PROVIDER=supabase
VITE_NODE_ENV=production
VITE_SUPABASE_URL=https://khdchqwieoqljevdhpvc.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtoZGNocXdpZW9xbGpldmRocHZjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQ2MTcxODUsImV4cCI6MjEwMDE5MzE4NX0.GEyVVWlMZB-gbFV7QTVmbVCkMSJ3s507aHRYRiYP51Q
VITE_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302
